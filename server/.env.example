# 数据库配置
MONGO_URI=mongodb://localhost:27017/contact-form

# 服务器配置
NODE_ENV=development
PORT=5001

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_API_KEY=your_admin_api_key
ADMIN_EMAIL=your-email@example.com
ADMIN_URL=http://localhost:3000/admin

# 邮件服务配置（Gmail示例）
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# 企业微信机器人配置
WECHAT_WORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-webhook-key

# 短信服务配置（阿里云示例）
SMS_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=流云智炬科技
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
ADMIN_PHONE=13800138000

# 钉钉机器人配置
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-access-token
DINGTALK_SECRET=your_dingtalk_secret

# 腾讯云短信配置（备选）
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_SMS_SIGN_NAME=流云智炬科技
TENCENT_SMS_TEMPLATE_CODE=123456